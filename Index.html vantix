<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Vantix — Build. Convert. Scale.</title>

  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet"/>

  <style>
    :root {
      --bg: #080808;
      --surface: #111111;
      --surface2: #161616;
      --border: rgba(255,255,255,0.07);
      --border-bright: rgba(255,255,255,0.14);
      --text: #f0f0f0;
      --text-muted: rgba(255,255,255,0.38);
      --text-mid: rgba(255,255,255,0.62);
      --accent: #e8f5e1;
      --accent-glow: #a8ff78;
      --accent2: #78c8ff;
      --white: #ffffff;
    }

    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

    body {
      font-family: 'Outfit', sans-serif;
      background: var(--bg);
      color: var(--text);
      overflow-x: hidden;
      cursor: none;
    }

    html { scroll-behavior: smooth; }

    /* CURSOR */
    .cursor, .cursor-ring {
      position: fixed;
      pointer-events: none;
      transform: translate(-50%, -50%);
      z-index: 9999;
    }

    .cursor {
      width: 10px; height: 10px;
      background: var(--accent-glow);
      border-radius: 50%;
    }

    .cursor-ring {
      width: 36px; height: 36px;
      border: 1px solid rgba(168,255,120,0.4);
      border-radius: 50%;
      transition: 0.2s;
    }

    /* NAV */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      display:flex;
      justify-content:space-between;
      padding:1.4rem 3rem;
      z-index:100;
      transition:0.3s;
    }

    nav.scrolled {
      background: rgba(8,8,8,0.9);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
    }

    .nav-logo {
      font-family:'Syne';
      font-weight:800;
      color:white;
      text-decoration:none;
    }

    .nav-logo span { color: var(--accent-glow); }

    .nav-links {
      display:flex;
      gap:2rem;
    }

    .nav-links a {
      color: var(--text-mid);
      text-decoration:none;
      font-size:0.85rem;
    }

    .nav-links a:hover { color:white; }

    .nav-cta {
      background:white;
      color:black !important;
      padding:0.5rem 1rem;
      border-radius:999px;
    }

    /* HERO */
    .hero {
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      text-align:center;
      padding:8rem 2rem;
    }

    .hero-title {
      font-family:'Syne';
      font-size:clamp(3rem,6vw,6rem);
      font-weight:800;
      line-height:1;
      text-shadow:0 2px 20px rgba(0,0,0,0.4);
    }

    .hero-title span {
      background: linear-gradient(135deg,#a8ff78,#78c8ff);
      -webkit-background-clip:text;
      -webkit-text-fill-color:transparent;
    }

    .hero-sub {
      color: rgba(255,255,255,0.7);
      max-width:600px;
      margin:1.5rem auto;
    }

    .btn-primary {
      background:white;
      color:black;
      padding:0.9rem 2rem;
      border-radius:999px;
      text-decoration:none;
      display:inline-block;
      margin-top:1rem;
    }

    /* SERVICES */
    .services {
      padding:7rem 3rem;
      max-width:1100px;
      margin:auto;
    }

    .section-title {
      font-family:'Syne';
      font-size:2.5rem;
      margin-bottom:1rem;
      text-shadow:0 2px 20px rgba(0,0,0,0.4);
    }

    .section-desc {
      color: rgba(255,255,255,0.7);
      margin-bottom:3rem;
    }

    /* PRICING */
    .pricing {
      padding:7rem 3rem;
      max-width:1100px;
      margin:auto;
    }

    .pricing-grid {
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:1.5rem;
      margin-top:3rem;
    }

    .price-card {
      background: rgba(255,255,255,0.03);
      border:1px solid rgba(255,255,255,0.08);
      border-radius:20px;
      padding:2rem;
      transition:0.3s;
    }

    .price-card:hover {
      transform:translateY(-5px);
      border-color: var(--accent-glow);
    }

    .price-card.featured {
      background: rgba(168,255,120,0.06);
      border-color: var(--accent-glow);
      transform: scale(1.03);
    }

    .price-amount {
      font-size:2.5rem;
      font-family:'Syne';
      margin:0.5rem 0;
    }

    .price-features {
      list-style:none;
      margin:1rem 0;
      color: var(--text-mid);
      font-size:0.85rem;
    }

    .price-features li { margin-bottom:0.5rem; }

    .price-btn {
      display:inline-block;
      padding:0.6rem 1.2rem;
      border-radius:999px;
      border:1px solid var(--border-bright);
      color:white;
      text-decoration:none;
    }

    .price-btn.primary {
      background:white;
      color:black;
    }

    /* CONTACT READABILITY FIX */
    .section-desc {
      color: rgba(255,255,255,0.72);
    }

    /* responsive */
    @media(max-width:900px){
      .pricing-grid{grid-template-columns:1fr;}
      nav .nav-links{display:none;}
    }

  </style>
</head>

<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<nav id="navbar">
  <a class="nav-logo">Van<span>tix</span></a>
  <div class="nav-links">
    <a href="#services">Services</a>
    <a href="#pricing">Pricing</a>
    <a href="#contact" class="nav-cta">Get Started</a>
  </div>
</nav>

<section class="hero">
  <div>
    <h1 class="hero-title">Websites that <span>actually convert.</span></h1>
    <p class="hero-sub">We build high-performance websites that turn traffic into revenue.</p>
    <a class="btn-primary" href="#contact">See What This Could Do For You</a>
  </div>
</section>

<section class="pricing" id="pricing">
  <h2 class="section-title">Simple pricing.</h2>
  <p class="section-desc">No fluff. Just results-driven builds.</p>

  <div class="pricing-grid">

    <div class="price-card">
      <h3>Starter</h3>
      <div class="price-amount">$1,500</div>
      <ul class="price-features">
        <li>1–3 page website</li>
        <li>Mobile optimized</li>
        <li>Lead forms</li>
      </ul>
      <a class="price-btn" href="#contact">Start</a>
    </div>

    <div class="price-card featured">
      <h3>Growth</h3>
      <div class="price-amount">$3,000</div>
      <ul class="price-features">
        <li>Full 5–8 pages</li>
        <li>Conversion system</li>
        <li>SEO optimized</li>
      </ul>
      <a class="price-btn primary" href="#contact">Most Popular</a>
    </div>

    <div class="price-card">
      <h3>Scale</h3>
      <div class="price-amount">$500/mo</div>
      <ul class="price-features">
        <li>Ongoing optimization</li>
        <li>A/B testing</li>
        <li>Growth tracking</li>
      </ul>
      <a class="price-btn" href="#contact">Book Call</a>
    </div>

  </div>
</section>

<footer style="text-align:center;padding:3rem;color:rgba(255,255,255,0.4);">
  © 2026 Vantix
</footer>

<script>
const cursor = document.getElementById('cursor');
const ring = document.getElementById('cursorRing');

document.addEventListener('mousemove', e=>{
  cursor.style.left = e.clientX+'px';
  cursor.style.top = e.clientY+'px';
  ring.style.left = e.clientX+'px';
  ring.style.top = e.clientY+'px';
});

window.addEventListener('scroll', ()=>{
  document.getElementById('navbar')
    .classList.toggle('scrolled', window.scrollY>40);
});
</script>

</body>
</html>
